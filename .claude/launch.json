{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", ".", "-l", "3001"],
      "port": 3001
    },
    {
      "name": "docs-server",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "docs", "-l", "3002"],
      "port": 3002
    },
    {
      "name": "python-server",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8001"],
      "port": 8001
    },
    {
      "name": "landing-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "landing"],
      "port": 5173
    },
    {
      "name": "landing-preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview", "--prefix", "landing"],
      "port": 4173
    }
  ]
}
